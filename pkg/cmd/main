#!/bin/bash
# WireGuard 服务端 — 生命周期脚本
# 管理监控守护进程的启动/停止/状态检查。

LOG_FILE="${TRIM_PKGVAR}/info.log"
mkdir -p "$(dirname "${LOG_FILE}")" 2>/dev/null
log_msg() { echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "${LOG_FILE}" 2>/dev/null; }

APP_DEST="${TRIM_APPDEST:-/var/apps/wg-server/target}"
PKG_VAR="${TRIM_PKGVAR:-/var/apps/wg-server/var}"
BINARY="${APP_DEST}/backend/wg-server"

mkdir -p "${PKG_VAR}" 2>/dev/null

SERVICE_NAME="wg-server-daemon"

case $1 in
start)
    systemctl start "${SERVICE_NAME}" 2>/dev/null
    if [ $? -eq 0 ]; then
        log_msg "${SERVICE_NAME} 服务已启动"
    else
        # 降级为直接启动
        if [ -x "${BINARY}" ]; then
            export TRIM_PKGVAR="${PKG_VAR}"
            nohup "${BINARY}" daemon >> "${LOG_FILE}" 2>&1 &
            PID=$!
            echo ${PID} > "${PKG_VAR}/monitor.pid"
            log_msg "监控守护进程已启动（降级）(PID: ${PID})"
        else
            log_msg "错误: 找不到 ${BINARY}"
            exit 1
        fi
    fi
    exit 0
    ;;
stop)
    systemctl stop "${SERVICE_NAME}" 2>/dev/null
    if [ $? -eq 0 ]; then
        log_msg "${SERVICE_NAME} 服务已停止"
    else
        # 降级直接杀死
        if [ -f "${PKG_VAR}/monitor.pid" ]; then
            PID=$(cat "${PKG_VAR}/monitor.pid")
            kill "${PID}" 2>/dev/null
            sleep 1
            log_msg "监控守护进程已停止（降级）(PID: ${PID})"
        fi
    fi
    rm -f "${PKG_VAR}/monitor.pid"
    exit 0
    ;;
status)
    systemctl is-active "${SERVICE_NAME}" 2>/dev/null && exit 0
    # 降级检查 PID
    if [ -f "${PKG_VAR}/monitor.pid" ]; then
        PID=$(cat "${PKG_VAR}/monitor.pid")
        if kill -0 "$PID" 2>/dev/null; then
            exit 0
        fi
    fi
    exit 0
    ;;
*)
    exit 1
    ;;
esac
