#!/bin/bash
### 安装后执行：确保 index.cgi 和 wg-server 可执行，重启 trim_http_cgi 使其生效。

LOG_FILE="${TRIM_PKGVAR}/info.log"
mkdir -p "$(dirname "${LOG_FILE}")" 2>/dev/null
log_msg() { echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "${LOG_FILE}" 2>/dev/null; }

APP_DEST="${TRIM_APPDEST:-/var/apps/wg-server/target}"

# 设置可执行权限
CGI="${APP_DEST}/ui/index.cgi"
if [ -f "$CGI" ]; then
    chmod +x "$CGI" 2>/dev/null
    log_msg "install_callback: chmod +x $CGI"
fi

BINARY="${APP_DEST}/backend/wg-server"
if [ -f "$BINARY" ]; then
    chmod +x "$BINARY" 2>/dev/null
    log_msg "install_callback: chmod +x $BINARY"
fi

# 创建 data 目录
PKG_VAR="${TRIM_PKGVAR:-/var/apps/wg-server/var}"
mkdir -p "${PKG_VAR}" 2>/dev/null
log_msg "install_callback: 数据目录 ${PKG_VAR}"

# 安装 wireguard-tools（wg 命令）
if ! command -v wg &>/dev/null; then
    apt-get update -qq 2>/dev/null && apt-get install -y -qq wireguard-tools 2>/dev/null && log_msg "wireguard-tools installed" || log_msg "wireguard-tools install failed (manual install needed)"
fi

# 启用 IP 转发
export DEBIAN_FRONTEND=noninteractive
tee /etc/sysctl.d/90-wg-server.conf >/dev/null <<EOF
net.ipv4.ip_forward=1
net.ipv6.conf.all.forwarding=1
EOF
sysctl -p /etc/sysctl.d/90-wg-server.conf 2>/dev/null || true
log_msg "IP forwarding enabled"

# 安装守护进程系统服务（自动拉起 + 开机自启）
SERVICE_FILE="/etc/systemd/system/wg-server-daemon.service"
cat > "${SERVICE_FILE}" <<SERVEOF
[Unit]
Description=WireGuard Server Monitoring Daemon
After=network.target
Before=trim_http_cgi.service

[Service]
Type=simple
ExecStart=${BINARY} daemon
Environment=TRIM_PKGVAR=${PKG_VAR}
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
SERVEOF
chmod 644 "${SERVICE_FILE}"
systemctl daemon-reload 2>/dev/null || true
systemctl enable wg-server-daemon.service 2>/dev/null && log_msg "wg-server-daemon 服务已启用" || log_msg "启用 wg-server-daemon 服务失败"
systemctl restart wg-server-daemon.service 2>/dev/null && log_msg "wg-server-daemon 已启动" || log_msg "启动 wg-server-daemon 失败"

# 让 fnOS 的 CGI 服务重新加载
systemctl restart trim_http_cgi.service 2>/dev/null && log_msg "restarted trim_http_cgi" || log_msg "restart trim_http_cgi failed (可能无权限，重启系统后生效)"

exit 0
